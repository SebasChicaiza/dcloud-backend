# Identity
NODE_ID=node-1
NODE_PRIORITY=100
CAN_BE_LEADER=true
LEADER_CAN_PROCESS=false

# Concurrency
WORKER_CONCURRENCY=auto
MAX_CONCURRENCY=4

# Redis
REDIS_URL=redis://redis:6379/0

# Run
RUN_ID=run-001

# Control plane (use "local" as host to simulate via a shared volume)
CONTROL_PLANE_HOST=10.0.0.5
CONTROL_PLANE_USER=ubuntu
CONTROL_PLANE_BASE_DIR=/data/dna-demo
CONTROL_PLANE_SSH_KEY=/root/.ssh/id_rsa
# When CONTROL_PLANE_HOST=local, files are copied to this directory directly
CONTROL_PLANE_LOCAL_DIR=/control-plane

# Local cache
LOCAL_DATA_DIR=/worker-cache

# Inputs
INPUT_A_NAME=A.clean
INPUT_B_NAME=B.clean

# Processing
CHUNK_SIZE_BYTES=33554432

# Leader election / heartbeat
LEADER_LOCK_TTL_MS=7000
LEADER_RENEW_INTERVAL_SECONDS=2
HEARTBEAT_INTERVAL_SECONDS=2
NODE_DEAD_AFTER_SECONDS=10

# SCP
SCP_CONNECT_TIMEOUT_SECONDS=10
SCP_RETRIES=3

# Stream / reclaim
JOB_MIN_IDLE_MS=30000
